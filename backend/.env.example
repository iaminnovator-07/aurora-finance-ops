# Aurora TIA Backend Configuration
APP_NAME=Aurora TIA
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Database — set to firestore to use Firebase Firestore as primary DB
DATABASE_BACKEND=postgresql
# DATABASE_BACKEND=firestore

# Firebase / Firestore
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=./credentials/firebase-service-account.json
# Local emulator (optional): FIRESTORE_EMULATOR_HOST=localhost:8080
DATABASE_URL=postgresql+asyncpg://aurora:aurora@localhost:5432/aurora_tia
DATABASE_URL_SYNC=postgresql://aurora:aurora@localhost:5432/aurora_tia

# JWT — CHANGE IN PRODUCTION
JWT_SECRET_KEY=aurora-tia-dev-secret-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini AI — set your key to enable full AI features
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# Gmail (optional — demo mode works without credentials)
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=./credentials/gmail_token.json
GMAIL_USER_EMAIL=

# Business thresholds
CONFIDENCE_AUTO_APPROVE_THRESHOLD=90.0
TRUST_AUTO_APPROVE_THRESHOLD=80.0
MANUAL_REVIEW_TRUST_THRESHOLD=60.0

# Analytics assumptions
MANUAL_INVOICE_PROCESSING_MINUTES=15.0
HOURLY_LABOR_COST_USD=45.0
LICENSE_COST_MONTHLY_USD=5000.0
